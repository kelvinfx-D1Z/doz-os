  category    String
  message     String
  severity    String   @default("INFO")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ContentLog {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  platform    String
  postUrl     String?
