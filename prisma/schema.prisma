// ============================================================
// MARKETING ENHANCEMENTS — SEO, Email List, Partnerships
// ============================================================

model SEOGap {
  id          String   @id @default(cuid())
  keyword     String
  searchIntent String  // informational, commercial, transactional
  difficulty  String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  status      String   @default("IDEA") // IDEA, DRAFTING, PUBLISHED
  title       String?
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  source      String   @default("WEBSITE") // WEBSITE, LEAD_MAGNET, NEWSLETTER, WAITLIST
  status      String   @default("ACTIVE") // ACTIVE, UNSUBSCRIBED
  createdAt   DateTime @default(now())
}

model Partnership {
  id          String   @id @default(cuid())
  partnerName String
  partnerType String   // EQUIPMENT_RENTAL, EVENT_PLANNER, HOTEL, CONFERENCE_CENTRE, NGO, GOVERNMENT, CREATIVE_AGENCY, SOFTWARE
  contactPerson String?
  email       String?
  phone       String?
  status      String   @default("IDENTIFIED") // IDENTIFIED, CONTACTED, MEETING_SCHEDULED, ACTIVE, DECLINED
  mutualBenefit String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// EQUIPMENT LIBRARY + PROJECT EQUIPMENT LISTS
// ============================================================

model EquipmentCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  icon        String?
  sortOrder   Int      @default(0)
  items       EquipmentItem[]
}

model EquipmentItem {
  id          String   @id @default(cuid())
  categoryId  String
  category    EquipmentCategory @relation(fields: [categoryId], references: [id])
  name        String
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ProjectEquipment {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  itemName    String
  category    String
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  totalPrice  Float    @default(0)
  vendorId    String?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])
  vendorName  String?
  vendorContact String?
  vendorPhone String?
  vendorEmail String?
  vendorBankDetails String?
  status      String   @default("LISTED") // LISTED, PRICED, APPROVED, ORDERED, DELIVERED, PAID
  notes       String?
  createdBy   String   // who added this (PM or founder)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// TIER 1: CONTRACTS, CASH FLOW, EVENT DAY, PRICING
// ============================================================

model Contract {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  title       String
  contractNumber String?
  status      String   @default("DRAFT") // DRAFT, SENT, SIGNED, ACTIVE, EXPIRED, TERMINATED
  value       Float
  startDate   DateTime?
  endDate     DateTime?
  signedDate  DateTime?
  signedBy    String?
  fileUrl     String?
  terms       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CashFlowForecast {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  type        String   // INFLOW, OUTFLOW
  amount      Float
  probability Int      @default(100) // 0-100 (for expected payments)
  category    String   // INVOICE_PAYMENT, VENDOR_PAYMENT, SALARY, RENT, SUBSCRIPTION, EQUIPMENT, OTHER
  projectId   String?
  source      String   // MANUAL, AUTO_INVOICE, AUTO_EXPENSE, AUTO_RECURRING
  createdAt   DateTime @default(now())
}

model EventDayLog {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  timestamp   DateTime @default(now())
  category    String   // CREW, EQUIPMENT, TECH, SCHEDULE, ISSUE, GENERAL
  message     String
  severity    String   @default("INFO") // INFO, WARNING, CRITICAL, RESOLVED
  reportedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
}

model EventDayStatus {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id])
  crewCheckedIn   Int  @default(0)
  crewTotal       Int  @default(0)
  equipmentLoaded Boolean @default(false)
  techCheckDone   Boolean @default(false)
  doorsOpen       Boolean @default(false)
  eventStarted    Boolean @default(false)
  eventEnded      Boolean @default(false)
  currentStep     String @default("PRE_EVENT") // PRE_EVENT, LOAD_IN, TECH_CHECK, DOORS, LIVE, WRAP, POST
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model PricingTemplate {
  id          String   @id @default(cuid())
  name        String   // e.g., "Conference Coverage Package"
  serviceType String
  description String?
  baseCost    Float    @default(0) // internal cost (PM can see this)
  basePrice   Float    @default(0) // company selling price (PM CANNOT see this)
  margin      Float    @default(0) // computed
  lineItems   String   // JSON array of {name, cost, price, quantity}
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// TIER 2: FEEDBACK, CREW AVAILABILITY, TIME TRACKING
// ============================================================

model ClientFeedback {
  // Note: projectId is not unique — a project can have multiple feedback entries over time

  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  rating      Int      // 1-5
  satisfactionScore Float? // 0-100
  whatWentWell String?
  whatCouldImprove String?
  wouldRecommend Boolean?
  testimonial String?
  testimonialApproved Boolean @default(false)
  submittedVia String  @default("PORTAL") // PORTAL, MANUAL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CrewAvailability {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime
  status      String   @default("AVAILABLE") // AVAILABLE, BOOKED, TENTATIVE, UNAVAILABLE
  projectId   String?  // if booked, which project
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  date        DateTime
  hours       Float
  description String?
  billable    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ============================================================
// TIER 3: VENDOR SCORING, POST-EVENT REVIEW, TAX, NOTIFICATIONS, COMPETITORS
// ============================================================

model VendorReview {
  id            String   @id @default(cuid())
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])
  qualityScore  Int      // 1-5
  timelinessScore Int    // 1-5
  professionalismScore Int // 1-5
  valueScore    Int      // 1-5
  overallScore  Float    @default(0) // computed average
  comments      String?
  reviewedBy    String?
  createdAt     DateTime @default(now())
}

model PostEventReview {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  timelineAdherence Int    @default(0) // 1-5
  budgetVariance   Float   @default(0) // % over/under budget
  clientSatisfaction Int   @default(0) // 1-5
  crewPerformance  Int     @default(0) // 1-5
  equipmentIssues  String?
  lessonsLearned   String?
  whatWentWell     String?
  whatWentWrong    String?
  whatToChange     String?
  completedBy      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TaxRecord {
  id          String   @id @default(cuid())
  taxType     String   // VAT, WITHHOLDING, PAYE, COMPANY_INCOME, OTHER
  period      String   // "2025-07"
  amount      Float
  status      String   @default("PENDING") // PENDING, FILED, PAID, OVERDUE
  dueDate     DateTime?
  filedDate   DateTime?
  paidDate    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationLog {
  id          String   @id @default(cuid())
  userId      String?
  type        String   // OVERDUE_INVOICE, PENDING_APPROVAL, TASK_ASSIGNED, EVENT_REMINDER, DIDI_CRITICAL, TAX_DUE
  title       String
  message     String
  severity    String   @default("INFO") // INFO, WARNING, CRITICAL
  isRead      Boolean  @default(false)
  entityType  String?
  entityId    String?
  sentVia     String   @default("IN_APP") // IN_APP, EMAIL
  createdAt   DateTime @default(now())
}

model Competitor {
  id            String   @id @default(cuid())
  name          String
  services      String?  // comma separated
  pricingRange  String?  // e.g., "₦2M-₦10M"
  keyClients    String?
  strengths     String?
  weaknesses    String?
  website       String?
  linkedin      String?
  instagram     String?
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

