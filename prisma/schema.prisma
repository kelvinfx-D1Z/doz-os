  reason        String
  successMetric String
  status        String   @default("FORECASTED")
  salaryBudget  Float?
  targetDate    DateTime?
  hiredName     String?
  hiredAt       DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FounderTimeLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  category    String
  hours       Float
  notes       String?
  createdAt   DateTime @default(now())
}

model WeeklyReview {
  id            String   @id @default(cuid())
  weekStart     DateTime
  content       String
  topPriorities String
  generatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
}

model MonthlyReport {
  id          String   @id @default(cuid())
  month       String
  content     String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AICoachingNudge {
